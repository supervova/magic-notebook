{
  "name": "magic-notebook-web",
  "version": "1.0.0",
  "description": "Official website for Magic Notebook, a calm writing app.",
  "author": "Vladimir Nikishin",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10"
  },
  "scripts": {
    "astro": "astro",
    "build": "astro build",
    "ci:local": "pnpm -s lint && pnpm -s typecheck && pnpm -s build",
    "dev": "node scripts/dev.js",
    "format": "prettier . --write",
    "lint": "pnpm -s lint:js && pnpm -s lint:css",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:js": "eslint .",
    "prebuild": "node scripts/build-svg-sprite.js && node scripts/optimize-public-images.js",
    "preview": "astro preview",
    "typecheck": "astro check"
  },
  "stylelint": {
    "extends": [
      "stylelint-config-standard"
    ],
    "ignoreFiles": [
      "src/components/progress/loader.css"
    ],
    "rules": {
      "alpha-value-notation": "number",
      "at-rule-empty-line-before": null,
      "at-rule-no-unknown": [
        true,
        {
          "ignoreAtRules": [
            "mixin",
            "define-mixin"
          ]
        }
      ],
      "at-rule-no-vendor-prefix": true,
      "color-named": "never",
      "comment-empty-line-before": [
        "always",
        {
          "except": [
            "first-nested"
          ],
          "ignore": [
            "after-comment",
            "stylelint-commands"
          ]
        }
      ],
      "custom-media-pattern": "^[a-z0-9-.]+$",
      "custom-property-empty-line-before": null,
      "declaration-block-no-redundant-longhand-properties": [
        true,
        {
          "ignoreShorthands": [
            "grid-template"
          ]
        }
      ],
      "declaration-empty-line-before": null,
      "declaration-no-important": true,
      "declaration-property-value-no-unknown": [
        true,
        {
          "ignoreProperties": {
            "/^(top|right|bottom|left|inset(?:-(?:block|inline)(?:-(?:start|end))?)?)$/": [
              "/^anchor\\(/"
            ]
          }
        }
      ],
      "font-family-name-quotes": "always-where-recommended",
      "font-weight-notation": [
        "numeric",
        {
          "ignore": [
            "relative"
          ]
        }
      ],
      "function-no-unknown": [
        true,
        {
          "ignoreFunctions": [
            "layer"
          ]
        }
      ],
      "function-url-no-scheme-relative": true,
      "function-url-quotes": "always",
      "hue-degree-notation": "number",
      "layer-name-pattern": "^[a-z0-9-.]+$",
      "length-zero-no-unit": [
        true,
        {
          "ignore": [
            "custom-properties"
          ],
          "ignoreFunctions": [
            "var"
          ]
        }
      ],
      "media-feature-name-no-unknown": [
        true,
        {
          "ignoreMediaFeatureNames": [
            "prefers-reduced-motion"
          ]
        }
      ],
      "media-feature-name-no-vendor-prefix": true,
      "no-descending-specificity": null,
      "no-duplicate-selectors": true,
      "no-empty-source": null,
      "no-invalid-position-declaration": [
        true,
        {
          "ignoreAtRules": [
            "define-mixin"
          ]
        }
      ],
      "property-no-unknown": [
        true,
        {
          "ignoreProperties": [
            "interpolate-size"
          ]
        }
      ],
      "property-no-vendor-prefix": true,
      "rule-empty-line-before": null,
      "selector-attribute-quotes": "always",
      "selector-class-pattern": [
        "^[a-z0-9-_\\/:\\[\\]]+$",
        {
          "message": "Class names should only contain lowercase letters, numbers, hyphens, underscores (for BEM elements only), and may include brackets, forward slashes for fractions and colons."
        }
      ],
      "selector-max-attribute": 3,
      "selector-max-class": 4,
      "selector-max-combinators": 4,
      "selector-max-compound-selectors": 4,
      "selector-max-id": 0,
      "selector-max-specificity": null,
      "selector-max-universal": 1,
      "selector-no-qualifying-type": null,
      "selector-no-vendor-prefix": true,
      "value-keyword-case": [
        "lower",
        {
          "camelCaseSvgKeywords": true,
          "ignoreFunctions": [
            "color-mix"
          ],
          "ignoreKeywords": [
            "Arial",
            "Baskerville",
            "BlinkMacSystemFont",
            "Consolas",
            "Georgia",
            "Inter",
            "Menlo",
            "Monaco",
            "Roboto",
            "SFMono-Regular",
            "Times"
          ]
        }
      ],
      "value-no-vendor-prefix": true
    }
  },
  "postcss": {
    "plugins": {
      "postcss-import": {},
      "postcss-mixins": {},
      "postcss-custom-media": {},
      "postcss-preset-env": {
        "stage": 2,
        "features": {
          "custom-properties": false,
          "custom-selectors": true,
          "is-pseudo-class": false,
          "cascade-layers": false,
          "case-insensitive-attributes": false,
          "nesting-rules": true
        }
      },
      "postcss-pxtorem": {
        "rootValue": 16,
        "propList": [
          "*",
          "!border*",
          "!outline*",
          "!box-shadow",
          "!text-shadow",
          "!filter",
          "!backdrop-filter",
          "!stroke*"
        ],
        "selectorBlackList": [],
        "exclude": null,
        "mediaQuery": false,
        "minPixelValue": 0
      },
      "postcss-calc": {},
      "postcss-discard-comments": {}
    }
  },
  "prettier": {
    "arrowParens": "always",
    "bracketSpacing": true,
    "endOfLine": "auto",
    "jsxSingleQuote": false,
    "printWidth": 100,
    "quoteProps": "as-needed",
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5",
    "overrides": [
      {
        "files": [
          "*.astro",
          "*.html"
        ],
        "options": {
          "printWidth": 40000,
          "bracketSameLine": true
        }
      }
    ]
  },
  "browserslist": [
    "> 0.5%",
    "last 2 versions",
    "not dead"
  ],
  "packageManager": "pnpm@10.28.2+sha512.41872f037ad22f7348e3b1debbaf7e867cfd448f2726d9cf74c08f19507c31d2c8e7a11525b983febc2df640b5438dee6023ebb1f84ed43cc2d654d2bc326264",
  "pnpm": {
    "ignoredBuiltDependencies": [
      "@parcel/watcher",
      "esbuild"
    ],
    "onlyBuiltDependencies": [
      "cwebp-bin",
      "esbuild",
      "gifsicle",
      "jpegtran-bin",
      "mozjpeg",
      "optipng-bin",
      "pngquant-bin",
      "sharp"
    ]
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@eslint/js": "^10.0.1",
    "astro": "^6.1.3",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.2.1",
    "globals": "^17.3.0",
    "postcss": "^8.4.38",
    "postcss-calc": "^10.1.1",
    "postcss-custom-media": "^12.0.0",
    "postcss-discard-comments": "^7.0.4",
    "postcss-import": "^16.1.0",
    "postcss-mixins": "^12.1.2",
    "postcss-preset-env": "^11.1.3",
    "postcss-pxtorem": "^6.1.0",
    "prettier": "^3.3.3",
    "sharp": "^0.34.5",
    "stylelint": "^17.1.1",
    "stylelint-config-standard": "^40.0.0",
    "svg-sprite": "^2.0.4",
    "typescript": "^6.0.2",
    "vite-plugin-imagemin": "^0.6.1"
  },
  "dependencies": {
    "embla-carousel": "^8.6.0"
  }
}
