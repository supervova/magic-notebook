---
import { getLocalizedPath } from '../../i18n/utils';
import type { Locale } from '../../i18n/config';

import Icon from '../ui/icon.astro';

interface BaseCopy {
  footer: string;
}

interface NavCopy {
  contact: string;
  privacy: string;
  supportTheProject: string;
  terms: string;
}

interface Props {
  baseCopy: BaseCopy;
  locale: Locale;
  navCopy: NavCopy;
}

const { baseCopy, locale, navCopy } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer class='footer'>
  <div class='container'>
    <div class='layout'>
      <p class='copy'>© Magic Notebook {currentYear}</p>
      <nav aria-label={baseCopy.footer}>
        <a href={getLocalizedPath(locale, 'contact-us')}>{navCopy.contact}</a>
        <a href={getLocalizedPath(locale, 'support-project')}>{navCopy.supportTheProject}</a>
        <a href={getLocalizedPath(locale, 'privacy')}>{navCopy.privacy}</a>
        <a href={getLocalizedPath(locale, 'terms')}>{navCopy.terms}</a>
        <a class="btn btn-icon btn-sm" href="https://x.com/magic_noteb00k" target="_blank" rel="noopener noreferrer" title="X.com">
          <Icon class="icon-sm" name="sm-social-x" />
          <span class="visually-hidden">X.com</span>
        </a>
      </nav>
    </div>
  </div>
</footer>
