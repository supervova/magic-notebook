---
import { Image } from 'astro:assets';

import logoMark from '../../assets/img/components/logomark.png';
import { getLocaleName, getLocalizedPath, getPathWithoutLocale } from '../../i18n/utils';
import type { Locale } from '../../i18n/config';
import { supportedLocales } from '../../i18n/config';

import Icon from '../ui/icon.astro';

interface BaseCopy {
  app: string;
  downloadMacos: string;
  downloadOptions: string;
  downloadWindows: string;
  downloadWindowsComingSoon: string;
  logo: string;
}

interface NavCopy {
  download: string;
  home: string;
  lang: string;
  supportTheProject: string;
  whatsNew: string;
}

interface Props {
  baseCopy: BaseCopy;
  locale: Locale;
  macosDownloadHref: string;
  navCopy: NavCopy;
  showBanner?: boolean;
  windowsDownloadHref: string;
}

const { baseCopy, locale, macosDownloadHref, navCopy, showBanner = false } = Astro.props;
const localeFlagNames = {
  en: 'flag-en',
  ru: 'flag-ru',
  de: 'flag-de',
  es: 'flag-es',
  fr: 'flag-fr',
  it: 'flag-it',
  pt: 'flag-pt-br',
  uk: 'flag-uk',
  ja: 'flag-ja',
  ko: 'flag-ko',
  zh: 'flag-zh',
} as const satisfies Record<Locale, string>;
const localeFlagName = localeFlagNames[locale];
const pathname = Astro.url.pathname.replace(/\/+$/, '') || '/';
const pathWithoutLocale = getPathWithoutLocale(pathname);

const isCurrentPath = (path: string) => {
  const localizedPath = getLocalizedPath(locale, path);
  const normalizedLocalizedPath = localizedPath.replace(/\/+$/, '') || '/';

  return pathname === normalizedLocalizedPath;
};
---

<header class='topnav'>
  {
    showBanner && (
      <div class='banner'>
        <Image
          alt={`${baseCopy.app}, ${baseCopy.logo}`}
          class="logomark"
          densities={[2]}
          src={logoMark}
          width={logoMark.width / 2}
        />
        <span class='brand-name'>{baseCopy.app}</span>
      </div>
    )
  }

  <div class='container'>
    <nav>
      <ul class='links'>
        <li>
          <a
            class='link link-home'
            href={getLocalizedPath(locale)}
            data-label={navCopy.home}
            aria-current={isCurrentPath('/') ? 'page' : undefined}
          >
            <Icon name='home' />
          </a>
        </li>
        <li>
          <details class='popover popover-center' data-role='popover'>
            <summary class='link'>
              {navCopy.download}
            </summary>
            <div class='body w-max'>
              <ul class='menu'>
                <li>
                  <a class='menu-item menu-item-icon-start' href={macosDownloadHref}>
                    <svg class='icon' aria-hidden='true' focusable='false'><use href='/assets/icons/sprite.svg#brand-apple'></use></svg>
                    <span class='label'>{baseCopy.downloadMacos}</span>
                  </a>
                </li>
                <li>
                  <span class='menu-item menu-item-icon-start' aria-disabled='true'>
                    <svg class='icon' aria-hidden='true' focusable='false'><use href='/assets/icons/sprite.svg#brand-windows'></use></svg>
                    <span class='label'>{baseCopy.downloadWindowsComingSoon}</span>
                  </span>
                </li>
              </ul>
            </div>
          </details>
        </li>
        <li>
          <a
            class='link'
            href={getLocalizedPath(locale, 'whats-new')}
            aria-current={isCurrentPath('whats-new') ? 'page' : undefined}
          >
            {navCopy.whatsNew}
          </a>
        </li>
        <li>
          <a
            class='link'
            href={getLocalizedPath(locale, 'support-project')}
            aria-current={isCurrentPath('support-project') ? 'page' : undefined}
          >
            {navCopy.supportTheProject}
          </a>
        </li>
        <li>
          <details class='popover popover-end' data-role='popover'>
            <summary aria-label={navCopy.lang}>
              <Icon name={localeFlagName} />
            </summary>
            <div class='body w-max'>
              <ul class='menu'>
                {
                  supportedLocales.map((availableLocale) => (
                    <li>
                      <a
                        class='menu-item'
                        href={getLocalizedPath(availableLocale, pathWithoutLocale)}
                        lang={availableLocale}
                        aria-current={locale === availableLocale ? 'true' : undefined}
                      >
                        {getLocaleName(availableLocale)}
                      </a>
                    </li>
                  ))
                }
              </ul>
            </div>
          </details>
        </li>
      </ul>
    </nav>
  </div>
</header>
