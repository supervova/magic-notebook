---
import PrivacyPage from '../templates/privacy.astro';
import { getCommonDictionary, getPageDictionary } from '../i18n/config';

const locale = 'en';
const commonDictionary = getCommonDictionary(locale);
const pageDictionary = getPageDictionary('privacy', locale);
---

<PrivacyPage locale={locale} commonDictionary={commonDictionary} pageDictionary={pageDictionary} />
